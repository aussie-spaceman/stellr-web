# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=<your_project_id>
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=<write_token_for_mutations>

# Site
NEXT_PUBLIC_SITE_URL=https://www.stellreducation.org

# Marketing pixels (add when accounts created)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://hwtzpfrnksksxlwwabqz.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon_key_from_supabase_dashboard>
SUPABASE_SERVICE_ROLE_KEY=<service_role_key_from_supabase_dashboard>

# Clerk Auth — get these from clerk.com dashboard after creating an application
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/account
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/account/onboarding

# Stripe
STRIPE_SECRET_KEY=<stripe_secret_key>
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=<stripe_publishable_key>
NEXT_PUBLIC_DONATION_URL=

# Email (Resend)
RESEND_API_KEY=<your_resend_api_key>
CONTACT_EMAIL=david.shaw@insimeducation.com
# Transactional sender — must be on a Resend-verified domain, never a personal
# mailbox (Gmail labels self-From mail as SENT, causing phantom duplicates).
TRANSACTIONAL_FROM=Stellr Education <no-reply@mail.stellreducation.org>
# Where member replies to transactional emails are delivered
TRANSACTIONAL_REPLY_TO=david.shaw@insimeducation.com

# Google Sheets (for group registration spreadsheet)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Google Places API (New) — school-address autofill on the registration form.
# Server-side only (NOT NEXT_PUBLIC_). Enable "Places API (New)" on the same
# GCP project as the service account above, then restrict the key to that API.
# Leave blank to disable autofill (the picker falls back to manual entry).
GOOGLE_PLACES_API_KEY=

# DocuSign — see https://developers.docusign.com/platform/auth/jwt-formula/
# Use account-d.docusign.com / demo.docusign.net for sandbox; account.docusign.com / your base path for production
DOCUSIGN_OAUTH_URL=https://account-d.docusign.com
DOCUSIGN_BASE_PATH=https://demo.docusign.net/restapi
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
# Full RSA private key PEM — use literal \n for newlines when stored as a single-line env var
DOCUSIGN_PRIVATE_KEY=
# Optional: pre-built consent form template ID from DocuSign admin (minor / guardian consent)
DOCUSIGN_TEMPLATE_ID=
# Adult & Mentor participation agreement template IDs (carry TeacherPhone / MentorPhone tabs)
DOCUSIGN_ADULT_TEMPLATE_ID=
DOCUSIGN_MENTOR_TEMPLATE_ID=
# Counter-signer added to the Mentor agreement (parallel signer). The template
# must define a 'StellrRepresentative' role at routing order 1. If unset, no
# counter-signer is added.
DOCUSIGN_STELLR_REP_NAME=Stellr Education
DOCUSIGN_STELLR_REP_EMAIL=
# HMAC key set in DocuSign Connect configuration for webhook signature verification
DOCUSIGN_CONNECT_HMAC_KEY=

# Vercel Cron — generate a random secret and set it in both .env.local and Vercel project settings
CRON_SECRET=

# Video conferencing — JaaS (8x8 Jitsi-as-a-Service). Powers in-portal video for
# Coaching/Mentoring sessions and live training lessons (lib/video-provider.ts).
# Get these from the JaaS console at https://jaas.8x8.vc → API Keys.
# Leave blank in dev: calls fall back to open meet.jit.si rooms with NO token.
#   VIDEO_PROVIDER       leave unset (default 'jaas'); set to 'zoom' to swap (stub)
#   JAAS_APP_ID          tenant id, looks like vpaas-magic-cookie-...
#   JAAS_KID             Key ID shown after uploading your public key,
#                        format "<JAAS_APP_ID>/<shortId>" e.g. vpaas-...-cookie-xxx/abc123
#   JAAS_PRIVATE_KEY     the RSA PRIVATE key PEM whose public half you uploaded;
#                        use literal \n for newlines when stored as one line
VIDEO_PROVIDER=
JAAS_APP_ID=
JAAS_KID=
JAAS_PRIVATE_KEY=
# Per-endpoint signing secret for the JaaS recording webhook (console →
# Webhooks → your endpoint → Reveal secret). Verifies X-Jaas-Signature on
# /api/webhooks/recording so recordings are offloaded to Supabase before the
# 24h JaaS link expires.
JAAS_WEBHOOK_SECRET=
# Optional shared secret for the legacy manual recording-offload path (testing).
RECORDING_WEBHOOK_SECRET=

# Web store — Printful (print-on-demand). See docs/WEB-STORE-PLAN.md.
# PRINTFUL_API_KEY    store-level API token from the Printful dashboard
#                     (Settings → Stores → API). Leave blank to disable the store.
# PRINTFUL_STORE_ID   only needed when using an ACCOUNT-level token to scope
#                     requests to one store (sent as X-PF-Store-Id).
# PRINTFUL_WEBHOOK_SECRET  random secret embedded in the Printful webhook URL
#                     (?secret=…) and matched on receipt — Printful v1 webhooks
#                     are not HMAC-signed. Stripe is reused for payments.
PRINTFUL_API_KEY=
PRINTFUL_STORE_ID=
PRINTFUL_WEBHOOK_SECRET=

# Background checks — Checkr (checkr.com). PRD §13. Stellr orders checks on behalf
# of adult non-students via the hosted-invite flow (Checkr emails the candidate to
# complete PII + FCRA consent on its own pages). Stellr is billed per report; the
# member is not charged. Provider is behind a seam (lib/background-provider) —
# leave the keys blank to disable ordering (the license-only path still works).
#   BACKGROUND_PROVIDER         provider id; defaults to 'checkr'
#   CHECKR_API_KEY              secret key (server-side); HTTP Basic, key as username
#   CHECKR_BASE_URL             https://api.checkr-staging.com/v1 (staging) |
#                               https://api.checkr.com/v1 (prod; email
#                               clients@checkr.com to enable live Reports)
#   CHECKR_PACKAGE_SLUG         criminal+identity package slug from YOUR dashboard
#   CHECKR_WORK_LOCATION_STATE  default 2-letter US state for work_locations
#                               (overridden by the member's licensing state)
#   CHECKR_WEBHOOK_SECRET       optional; defaults to CHECKR_API_KEY. Checkr signs
#                               with X-Checkr-Signature = HMAC-SHA256(rawBody, key),
#                               verified on /api/webhooks/background.
#   NEXT_PUBLIC_CHECKR_DASHBOARD_URL  base for the admin "view report in Checkr"
#                               link; https://dashboard.checkr-staging.com (staging)
#                               | https://dashboard.checkr.com (prod). Default prod.
BACKGROUND_PROVIDER=checkr
CHECKR_API_KEY=
CHECKR_BASE_URL=https://api.checkr-staging.com/v1
CHECKR_PACKAGE_SLUG=
CHECKR_WORK_LOCATION_STATE=
CHECKR_WEBHOOK_SECRET=
NEXT_PUBLIC_CHECKR_DASHBOARD_URL=https://dashboard.checkr-staging.com
