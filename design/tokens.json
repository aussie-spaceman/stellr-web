{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Stellr Education design tokens — single source of truth. Build per-platform outputs (CSS vars + TS, Swift, Compose/XML) with Style Dictionary. Never hard-code these values in component code.",
  "color": {
    "midnight":     { "$type": "color", "$value": "#0E1330", "$description": "Page / footer background" },
    "midnightDeep": { "$type": "color", "$value": "#141A3D", "$description": "Hero gradient bottom stop" },
    "heroLead":     { "$type": "color", "$value": "#C3CBF0", "$description": "Lead text on navy hero" },
    "heroDim":      { "$type": "color", "$value": "#9FB0FF", "$description": "Breadcrumb / dim accent on navy hero" },
    "ink":          { "$type": "color", "$value": "#13183A", "$description": "Headings" },
    "utilityNavy":  { "$type": "color", "$value": "#0A1B3C", "$description": "Header top utility bar" },
    "surface":      { "$type": "color", "$value": "#F6F7FB", "$description": "Section / panel background" },
    "white":        { "$type": "color", "$value": "#FFFFFF" },
    "primary":      { "$type": "color", "$value": "#3C6DF6", "$description": "Primary action / CTA" },
    "primaryDeep":  { "$type": "color", "$value": "#2C53C6", "$description": "Hover / gradient end" },
    "donateGold":   { "$type": "color", "$value": "#E0A23A", "$description": "Donate button" },
    "starGold":     { "$type": "color", "$value": "#FFC24B", "$description": "Highlight / milestone" },
    "spaceViolet":  { "$type": "color", "$value": "#7C5CFC", "$description": "Theme: Space" },
    "enviroGreen":  { "$type": "color", "$value": "#1FA97A", "$description": "Theme: Environmental" },
    "pathwayAmber": { "$type": "color", "$value": "#E0922F", "$description": "Pathway: Campaign" },
    "pathwayAmberDeep": { "$type": "color", "$value": "#C2722A", "$description": "Pathway amber hover / gradient end" },
    "avatarTeal":   { "$type": "color", "$value": "#16B6C4", "$description": "Account avatar" },
    "text": {
      "primary":   { "$type": "color", "$value": "#2A2F45" },
      "body":      { "$type": "color", "$value": "#454B68" },
      "secondary": { "$type": "color", "$value": "#5A6178" },
      "muted":     { "$type": "color", "$value": "#6A708C" },
      "faint":     { "$type": "color", "$value": "#8A90AD" }
    },
    "border":      { "$type": "color", "$value": "#E4E7F2", "$description": "Card / divider border" },
    "borderLight": { "$type": "color", "$value": "#ECEEF6" },
    "danger":      { "$type": "color", "$value": "#B0554D", "$description": "Avoid / negative copy" }
  },
  "bracket": {
    "$description": "Age-bracket identity colours (audience colour-coding). base = existing brand colour; tint = soft panel/icon-chip fill; deep = hover/pressed. Deliberately NOT green or gold (those mean included/free and support/donate).",
    "school":     { "$type": "color", "$value": "#3C6DF6", "$description": "High-school students — aliases color.primary" },
    "schoolTint": { "$type": "color", "$value": "#EAF0FE" },
    "schoolDeep": { "$type": "color", "$value": "#2C53C6", "$description": "= color.primaryDeep" },
    "college":     { "$type": "color", "$value": "#7C5CFC", "$description": "College students — aliases color.spaceViolet" },
    "collegeTint": { "$type": "color", "$value": "#F4F0FF" },
    "collegeDeep": { "$type": "color", "$value": "#5B3FD6" },
    "adult":     { "$type": "color", "$value": "#16B6C4", "$description": "Adults / educators — aliases color.avatarTeal" },
    "adultTint": { "$type": "color", "$value": "#E4F7F9" },
    "adultDeep": { "$type": "color", "$value": "#0E8C99" }
  },
  "tier": {
    "$description": "Per-tier shade ramps within each bracket (free/base = light → top tier = deep). Use for anything representing a specific tier: TierCard strip/price/selected, accumulation bars, viewing badges, bracket-key chips.",
    "explorer":    { "$type": "color", "$value": "#7AA0FB", "$description": "High-school · base" },
    "pathfinder":  { "$type": "color", "$value": "#3C6DF6", "$description": "High-school" },
    "scholar":     { "$type": "color", "$value": "#1E3FA8", "$description": "High-school · top" },
    "alumni":      { "$type": "color", "$value": "#A892FD", "$description": "College · base" },
    "contributor": { "$type": "color", "$value": "#7C5CFC", "$description": "College" },
    "counselor":   { "$type": "color", "$value": "#4E2EC2", "$description": "College · top" },
    "educator":    { "$type": "color", "$value": "#5FD3DD", "$description": "Adults · base" },
    "catalyst":    { "$type": "color", "$value": "#16B6C4", "$description": "Adults" },
    "innovator":   { "$type": "color", "$value": "#0E8C99", "$description": "Adults" },
    "trailblazer": { "$type": "color", "$value": "#0A6470", "$description": "Adults · top" }
  },
  "themeTint": {
    "spaceBg":   { "$type": "color", "$value": "#F6F2FF" },
    "spaceChip": { "$type": "color", "$value": "#EDE6FF" },
    "spaceText": { "$type": "color", "$value": "#3B2B86" },
    "enviroBg":   { "$type": "color", "$value": "#EDFAF4" },
    "enviroChip": { "$type": "color", "$value": "#DCF3EA" },
    "enviroText": { "$type": "color", "$value": "#0F6A4C" },
    "primarySoftBg": { "$type": "color", "$value": "#EAF0FE" },
    "amberSoftBg":   { "$type": "color", "$value": "#FBEFDD" }
  },
  "font": {
    "display": { "$type": "fontFamily", "$value": "Space Grotesk", "$description": "Headings & display, weights 500–700" },
    "body":    { "$type": "fontFamily", "$value": "Hanken Grotesk", "$description": "Body & UI, weights 400–700" },
    "competitionDisplay": { "$type": "fontFamily", "$value": "Norwester", "$description": "Competition-materials headings (print/slides)" },
    "competitionBody":    { "$type": "fontFamily", "$value": "Aileron", "$description": "Competition-materials body (print/slides)" }
  },
  "fontSize": {
    "h1":      { "$type": "dimension", "$value": "56px" },
    "h2":      { "$type": "dimension", "$value": "32px" },
    "h3":      { "$type": "dimension", "$value": "18px" },
    "eyebrow": { "$type": "dimension", "$value": "13px", "$description": "Uppercase, letter-spacing .13em" },
    "lead":    { "$type": "dimension", "$value": "18px" },
    "body":    { "$type": "dimension", "$value": "15px" },
    "meta":    { "$type": "dimension", "$value": "13px" }
  },
  "letterSpacing": {
    "display": { "$type": "dimension", "$value": "-0.025em" },
    "heading": { "$type": "dimension", "$value": "-0.02em" },
    "eyebrow": { "$type": "dimension", "$value": "0.13em" }
  },
  "radius": {
    "control": { "$type": "dimension", "$value": "8px" },
    "card":    { "$type": "dimension", "$value": "14px" },
    "panel":   { "$type": "dimension", "$value": "18px" },
    "cta":     { "$type": "dimension", "$value": "22px" },
    "pill":    { "$type": "dimension", "$value": "999px" }
  },
  "space": {
    "section":    { "$type": "dimension", "$value": "64px", "$description": "Vertical rhythm between blocks (64–72)" },
    "gutter":     { "$type": "dimension", "$value": "32px", "$description": "Horizontal page padding" },
    "contentMax": { "$type": "dimension", "$value": "1080px", "$description": "Content column max width" },
    "chromeMax":  { "$type": "dimension", "$value": "1240px", "$description": "Header/footer max width" }
  },
  "shadow": {
    "cardLift": { "$type": "shadow", "$value": "0 18px 40px -30px rgba(20,26,61,0.4)" },
    "featured": { "$type": "shadow", "$value": "0 18px 40px -28px rgba(60,109,246,0.6)" },
    "panel":    { "$type": "shadow", "$value": "0 18px 50px -40px rgba(20,26,61,0.4)" }
  }
}
